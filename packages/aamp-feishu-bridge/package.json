{
  "name": "@zengxingyuan/aamp-feishu-bridge",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "version": "0.1.42",
  "description": "Local Feishu bridge daemon for connecting a user-owned Feishu bot to a target AAMP agent.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aamp-feishu-bridge": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "prepare-bin": "node -e \"require('node:fs').chmodSync('dist/index.js', 0o755)\"",
    "prepack": "npm run build && npm run prepare-bin",
    "prepublishOnly": "npm run build && npm run prepare-bin",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.63.1",
    "aamp-sdk": "npm:@luckyterry/aamp-sdk@0.1.24-dev.1",
    "pino": "^9.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
